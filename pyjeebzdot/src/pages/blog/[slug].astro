---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ReactionsWrapper from '../../components/react/ReactionsWrapper';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await post.render();
---

<Layout title={`${post.data.title} - Akinkunmi`}>
  <article>
    <a href="/blog" class="text-2xs uppercase tracking-[0.14em] text-muted-faint mb-10 inline-block hover:text-accent transition-colors">&larr; Blog</a>
    
    <h1 class="font-serif text-[clamp(1.75rem,5vw,2.35rem)] font-medium text-off-white leading-snug tracking-tight mb-3">{post.data.title}</h1>
    <time class="text-2xs uppercase tracking-[0.12em] text-muted-faint block mb-10 pb-8 border-b border-hairline">
      {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
    </time>
    
    <div class="prose prose-invert prose-zinc max-w-none">
      <Content />
    </div>
    
    <ReactionsWrapper slug={post.slug} client:only="react" />
  </article>
</Layout>

<style is:global>
  .prose h2 {
    @apply font-serif text-xl font-medium text-off-white mt-10 mb-4 tracking-tight;
  }
  .prose h3 {
    @apply font-serif text-lg font-medium text-off-white mt-8 mb-3 tracking-tight;
  }
  .prose p {
    @apply text-muted leading-relaxed mb-4;
  }
  .prose ul {
    @apply text-muted list-disc list-inside mb-4 space-y-1;
  }
  .prose ol {
    @apply text-muted list-decimal list-inside mb-4 space-y-1;
  }
  .prose a {
    @apply text-off-white underline underline-offset-[5px] decoration-white/20 hover:text-accent hover:decoration-accent/50 transition-colors;
  }
  .prose code {
    @apply bg-white/[0.06] px-1.5 py-0.5 rounded text-sm text-off-white;
  }
  .prose pre {
    @apply bg-white/[0.04] border border-hairline p-4 rounded-md overflow-x-auto mb-4;
  }
  .prose blockquote {
    @apply border-l border-hairline pl-4 italic text-muted-faint my-4;
  }
</style>
